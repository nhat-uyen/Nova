# ── Nova credentials ────────────────────────────────────────────
# IMPORTANT: Change both values before any deployment.
# Defaults (nova / nova) are intentionally weak and must not be used in production.
NOVA_USERNAME=admin
NOVA_PASSWORD=changeme
NOVA_SECRET_KEY=change-this-to-a-long-random-string

# ── Release channel ───────────────────────────────────────────
# Controls which release tier this instance serves.
# Values: stable | beta | alpha
# Setting NOVA_CHANNEL=alpha activates the GitHub OAuth gate (see below).
# Any value other than stable/beta/alpha falls back to stable.
NOVA_CHANNEL=stable
NOVA_BRANCH=main

# ── Admin UI ──────────────────────────────────────────────
# Set to "true" to enable admin-only UI controls (e.g. branch display).
NOVA_ADMIN_UI=false

# ── Alpha channel — GitHub OAuth gate ─────────────────────────────
# The following variables are REQUIRED when NOVA_CHANNEL=alpha.
# If GITHUB_CLIENT_ID or GITHUB_CLIENT_SECRET are missing, the server
# returns 503 for all requests rather than granting open access.
#
# NOVA_ALPHA_ALLOWED_USERS must be set explicitly. An empty value locks out
# every user, including the GitHub account that owns the OAuth app.
# Use a comma-separated list of GitHub usernames (case-insensitive).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://your-alpha-domain/auth/github/callback
NOVA_ALPHA_ALLOWED_USERS=githubusername1,githubusername2
