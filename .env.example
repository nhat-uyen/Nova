# ── Nova credentials ────────────────────────────────────────────
# IMPORTANT: Change both values before any deployment.
# Defaults (nova / nova) are intentionally weak and must not be used in production.
NOVA_USERNAME=admin
NOVA_PASSWORD=changeme
NOVA_SECRET_KEY=change-this-to-a-long-random-string

# ── Release channel ───────────────────────────────────────────
# Controls which release tier this instance serves.
# Values: stable | beta | alpha
# Setting NOVA_CHANNEL=alpha activates the GitHub OAuth gate (see below).
# Any value other than stable/beta/alpha falls back to stable.
NOVA_CHANNEL=stable
NOVA_BRANCH=main

# ── Admin UI ──────────────────────────────────────────────
# Set to "true" to enable admin-only UI controls (e.g. branch display).
NOVA_ADMIN_UI=false

# ── Alpha channel — GitHub OAuth gate ─────────────────────────────
# The following variables are REQUIRED when NOVA_CHANNEL=alpha.
# If GITHUB_CLIENT_ID or GITHUB_CLIENT_SECRET are missing, the server
# returns 503 for all requests rather than granting open access.
#
# NOVA_ALPHA_ALLOWED_USERS must be set explicitly. An empty value locks out
# every user, including the GitHub account that owns the OAuth app.
# Use a comma-separated list of GitHub usernames (case-insensitive).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://your-alpha-domain/auth/github/callback
NOVA_ALPHA_ALLOWED_USERS=githubusername1,githubusername2

# ── Automatic web/RSS learning ─────────────────────────────────────────
# Set to "true" to enable background RSS feed learning every hour.
# Disabled by default to prevent low-value entries from polluting the memory DB.
NOVA_AUTO_WEB_LEARNING=false

# ── Optional integrations ─────────────────────────────────────────────
# SilentGuard and NexaNote are disabled per-user by default and must be
# turned on from Settings → Integrations. The variables below only set
# the *transport* — they never enable an integration on their own.
#
# SilentGuard reads ~/.silentguard_memory.json; override the path with:
# NOVA_SILENTGUARD_PATH=/custom/path/to/feed.json
#
# NexaNote is reached over HTTP; leave NEXANOTE_API_URL empty to keep
# the integration unavailable for everyone.
NEXANOTE_API_URL=
NEXANOTE_API_TOKEN=
NEXANOTE_TIMEOUT_SECONDS=3.0

# ── Time / calendar context ───────────────────────────────────────────
# Override the timezone Nova uses when resolving "today", "yesterday", etc.
# Must be a valid IANA timezone name (e.g. America/Montreal, Europe/Paris).
# Falls back to the system timezone (/etc/timezone) when not set.
NOVA_TIMEZONE=
